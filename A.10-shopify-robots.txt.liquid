{%- comment -%}
Create this file at templates/robots.txt.liquid in your theme.
This overrides Shopify's default robots.txt output.
The for-loop at the top preserves Shopify's default disallows for /admin,
/cart, /orders, /checkouts/ and the search-parameter paths.
Test the live URL at yourstore.com/robots.txt after deploying.
{%- endcomment -%}

{% for group in robots.default_groups %}
  {{- group.user_agent }}
  {%- for rule in group.rules -%}
    {{ rule }}
  {%- endfor -%}
  {%- if group.sitemap != blank %}
    {{ group.sitemap }}
  {%- endif %}
{% endfor %}

