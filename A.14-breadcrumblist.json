{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://{{ DOMAIN.COM }}/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ CATEGORY_NAME }}",
      "item": "https://{{ DOMAIN.COM }}/collections/{{ CATEGORY_SLUG }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ PRODUCT_NAME }}",
      "item": "https://{{ DOMAIN.COM }}/products/{{ PRODUCT_SLUG }}"
    }
  ]
}
